# NAV Online Számla API Configuration
# Copy to .env and fill in real values before running.

# Registered software ID from NAV Online Számla portal (required)
NAV_SOFTWARE_ID=HU00000000-0000

# Technical user credentials
NAV_TECHNICAL_USER=
NAV_PASSWORD=
NAV_SIGNATURE_KEY=
NAV_REPLACEMENT_KEY=
NAV_TAX_NUMBER=

# ── Email Backend ─────────────────────────────────────────────────────────
# Supported: gmail, sendgrid (Phase 3), ses (Phase 3)
EMAIL_BACKEND=gmail

# Gmail SMTP (required when EMAIL_BACKEND=gmail)
SMTP_EMAIL=
SMTP_PASSWORD=
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# SendGrid (Phase 3)
# SENDGRID_API_KEY=

# Amazon SES (Phase 3)
# AWS_SES_REGION=eu-central-1
# AWS_SES_ACCESS_KEY_ID=
# AWS_SES_SECRET_ACCESS_KEY=

# ── Vendor Upload Links ──────────────────────────────────────────────────
APP_BASE_URL=https://app.navvoice.hu
UPLOAD_LINK_SECRET=
UPLOAD_LINK_EXPIRY_HOURS=168
